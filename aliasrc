# Reset: Remove all existing aliases
unalias -a

# Detect linux o darwin
local detected_os
detected_os=$(uname -s)

# Aliases
alias py='python3'
#alias podup='systemctl --user start podman'
#alias podman='podman-remote'
#alias docker='podman-remote'
alias perms="stat -c '%a - %n'"
alias fetch='fastfetch'
alias so='du -ahd 1'
alias rm='rm -rf'
alias bat='batcat'
if [ -x /usr/bin/dircolors ]; then
    #test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto --group-directories-first'
    #alias dir='dir --color=auto'
    #alias vdir='vdir --color=auto'
fi
alias path='echo -e ${PATH//:/\\n}'
alias l='ls -CF'
alias ll='ls -alF'
alias la='ls -A'
alias lt='ls --human-readable --size -1 -S --classify'
alias tree='l --tree'
alias mkdir='mkdir -pv'
mk() {
  mkdir --parents "$1" && cd "$1"
}
alias count='find . -type f | wc -l'
alias cpv='rsync -ah --info=progress2'
alias du='du --human-readable'
alias time='/usr/bin/time -f "\nElapsed: %E\nCPU: %P\nMax RAM: %M KB\n"'
alias which='type -a' # 'type -a' is more robust in Zsh than 'which'

# Move dir
alias .="pwd"
alias ..="cd .."
alias ...="cd ../.."
alias .3="cd ../../.."
alias .4="cd ../../../.."
alias .5="cd ../../../../.."

# Change Grep
if (( $+commands[rg] )); then
  alias grep="rg"
  alias -g ':G'='| rg'
else
  alias -g ':G'='| grep'
fi

# Safety nets
alias rm='rm -I --preserve-root'
alias chown='chown --preserve-root'
alias chmod='chmod --preserve-root'
alias chgrp='chgrp --preserve-root'

# Update Debian
alias update='sudo apt-get update && sudo apt-get upgrade'

# Root
alias -- _="sudo"
alias root='sudo -i'
alias su='sudo -i'

# Docker
alias dl='docker ps -l -q'
alias dps='docker ps'
alias di='docker images'
alias dip="docker inspect --format '{{ .NetworkSettings.IPAddress }}'"
alias dkd='docker run -d -P'
alias dki='docker run -i -t -P'
alias dex='docker exec -i -t'

# Terraform
alias tf='terraform'

# Ansible
alias avault="uv tool run --from ansible-core ansible-vault"

# TMUX
# Start or attach to the default tmux session
alias tn='tmux new -s'                 # New named session
alias ta='tmux attach -t'              # Attach to session
alias tk='tmux kill-session -t'        # Kill session
alias tl='tmux ls'                     # List sessions
alias tK='tmux kill-server'            # Kill everything (Server shutdown)
alias tmuxa='tmux has-session -t session 2>/dev/null && tmux attach -t session || tmux new -s session'
# Smart Exit:
    # If in Tmux: Kill the specific session.
    # If in Zsh:  Just exit the shell.
alias ':q'='[ -n "$TMUX" ] && tmux kill-session -t $(tmux display-message -p "#S") || exit'
